# Copy this file to ".env.local" and fill in the values below.
# .env.local is git-ignored, so your keys stay private.

# Supabase (dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-long-anon-key...

# Supabase service role — server only, never expose to the browser.
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...service-role-key...

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com

# Random secret for the daily weigh-in reminder cron
CRON_SECRET=some-long-random-string
